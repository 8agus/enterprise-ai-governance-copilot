{
  "name": "enterprise-ai-governance-copilot",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "npm -w apps/api run dev",
    "dev:dashboard": "npm -w apps/dashboard run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "start": "npm run start:dashboard",
    "start:dashboard": "npm -w apps/dashboard run start"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.9",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}

