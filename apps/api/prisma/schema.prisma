generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuditRun {
  id        String   @id @default(uuid())
  repoUrl   String
  status    String   @default("pending")
  findings  Json?
  createdAt DateTime @default(now())
}