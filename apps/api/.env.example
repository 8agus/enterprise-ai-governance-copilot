# API runtime
PORT=3001
# Set to the deployed dashboard origin for production.
CORS_ORIGIN=http://localhost:3000

# Persistence
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_ai_governance?schema=public

# Optional: GitHub ingestion for private repos
GITHUB_TOKEN=

# Microsoft Foundry / Azure OpenAI (Ticket 29)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
# Optional override; defaults to 2024-10-21 in code
AZURE_OPENAI_API_VERSION=2024-10-21
